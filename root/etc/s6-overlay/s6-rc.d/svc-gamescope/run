#!/bin/bash
# shellcheck shell=bash
#
# s6 longrun: gamescope driving the real HDMI display, with Steam as its child.
#
# Runs as ROOT (DRM master requires root; the privileged container grants it).
# gamescope's builtin seatd acquires the seat without systemd logind. Steam is
# launched as `abc` via runuser so game state/ownership on the /config PVC is
# preserved.
#
# Configuration via env (defaults shown):
#   STEAM_GAMESCOPE_CONNECTOR=HDMI-A-2   DRM connector to drive
#   STEAM_GAMESCOPE_WIDTH=1600           output width
#   STEAM_GAMESCOPE_HEIGHT=900           output height
#   STEAM_GAMESCOPE_REFRESH=60           output refresh rate

set -u

# s6's with-contenv shebang restores /run/s6/container_environment which would
# clobber our exports. We source the container env explicitly then override.
[ -d /run/s6/container_environment ] && for f in /run/s6/container_environment/*; do
  [ -f "$f" ] && export "$(basename "$f")=$(cat "$f")"
done

# Persist our overrides into the container env too (so children inherit).
mkdir -p /run/s6/container_environment
printf '%s' /config/.XDG > /run/s6/container_environment/XDG_RUNTIME_DIR
printf '%s' 1 > /run/s6/container_environment/WLR_LIBINPUT_NO_DEVICES

CONNECTOR="${STEAM_GAMESCOPE_CONNECTOR:-HDMI-A-2}"
WIDTH="${STEAM_GAMESCOPE_WIDTH:-1600}"
HEIGHT="${STEAM_GAMESCOPE_HEIGHT:-900}"
REFRESH="${STEAM_GAMESCOPE_REFRESH:-60}"
export PATH="/usr/games:/usr/bin:/bin:/usr/sbin:${PATH}"
export WLR_LIBINPUT_NO_DEVICES=1
export HOME=/config
export XDG_RUNTIME_DIR=/config/.XDG
unset WAYLAND_DISPLAY DISPLAY

# gamescope must own /tmp/.X11-unix for its Xwayland, else it errors out.
mkdir -p /tmp/.X11-unix
chown root:root /tmp/.X11-unix
chmod 1777 /tmp/.X11-unix
rm -f /tmp/.X11-unix/* 2>/dev/null

# Clean stale sockets (the /config PVC persists them across restarts).
rm -f "${XDG_RUNTIME_DIR}"/gamescope-* "${XDG_RUNTIME_DIR}"/wayland-* 2>/dev/null || true

# gamescope is both the compositor and the capture source. Its child is a
# wrapper that opens X11 auth (xhost +local:) then drops to `abc` for Steam
# (Steam refuses root; Xwayland is created by root so auth must be opened).
exec /usr/games/gamescope \
  --backend drm \
  -O "${CONNECTOR}" \
  -W "${WIDTH}" -H "${HEIGHT}" -r "${REFRESH}" \
  --steam \
  -- /usr/bin/gamescope-steam-wrapper
