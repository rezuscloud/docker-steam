#!/bin/bash
# shellcheck shell=bash
# custom-cont-init.d: bridge Steam's pressure-vessel runtime path to the live
# session dir. The base image runs the session with XDG_RUNTIME_DIR=/config/.XDG,
# but Steam's pressure-vessel sandbox rewrites it to /run/user/1000 (the systemd
# standard). Steam's PipeWire capture then looks for the socket at
# /run/user/1000/pipewire-0 which doesn't exist -> "PipeWire: Timed out waiting
# for initialization" -> no video. Symlink both paths so it resolves.
#
# /run is tmpfs (wiped each boot), so this runs every cont-init.
set -e
if [ -e /run/user/1000 ] && [ ! -L /run/user/1000 ]; then
  echo "[steam-runtime-bridge] /run/user/1000 exists and is not a symlink; leaving as-is"
else
  echo "[steam-runtime-bridge] bridging /run/user/1000 -> /config/.XDG"
  mkdir -p /config/.XDG
  chown abc:abc /config/.XDG
  rm -rf /run/user/1000
  ln -s /config/.XDG /run/user/1000
fi
